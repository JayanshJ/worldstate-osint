# ─── Copy to .env and fill in values ─────────────────────────────────────

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=worldstate
POSTGRES_PASSWORD=worldstate_secret
POSTGRES_DB=worldstate

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI — required for embeddings + GPT-4o-mini fallback
OPENAI_API_KEY=sk-...

# Google Gemini — primary intelligence model (leave blank to use OpenAI only)
GOOGLE_API_KEY=

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WorldState/1.0

# Twitter/X Bearer Token (optional — for timeline scraping)
TWITTER_BEARER_TOKEN=

# ─── Tuning ───────────────────────────────────────────────────────────────
CLUSTER_TRIGGER_THRESHOLD=5
CLUSTER_COSINE_THRESHOLD=0.18
DEDUP_SIMILARITY_THRESHOLD=0.92
INGESTION_INTERVAL_SECONDS=120
CLUSTER_RUN_INTERVAL_SECONDS=60
